function updateProduct() {
  const product = document.getElementById("productSelect").value;
  const row = DATA.summary.find(r => r.product === product);
  document.getElementById("detailName").textContent = product;
  const ps = document.getElementById("detailProductStatus");
  ps.textContent = "Product: " + row.product_status; ps.className = productCls(row.product_status);
  const ss = document.getElementById("detailSalesStatus");
  ss.textContent = "Sales: " + row.sales_status; ss.className = salesCls(row.sales_status);
  document.getElementById("dTotal").textContent = fmt(row.total);
  document.getElementById("dAvg").textContent = row.avg_weekly;
  document.getElementById("dWeeks").textContent = row.weeks_with_sales;
  document.getElementById("dPeak").textContent = row.peak_week;
  document.getElementById("dPeakUnits").textContent = fmt(row.peak_units);
  document.getElementById("dTrend").textContent = row.trend;

  Plotly.newPlot("lineChart", [{
    x: DATA.weeks, y: seriesFor(product), type:"scatter", mode:"lines+markers",
    hovertemplate:"Week: %{x}<br>Units sold: %{y}<extra></extra>"
  }], {
    title: "Weekly net items sold",
    margin: {t:50,l:55,r:20,b:50},
    xaxis: {title:"Week"},
    yaxis: {title:"Units sold", rangemode:"tozero"}
  }, {responsive:true, displaylogo:false});

  renderInsights(row);
}
function renderInsights(row) {
  const div = document.getElementById("insights");
  const top = DATA.summary.filter(r => r.total > 0).sort((a,b) => b.total-a.total)[0];
  const noSales = DATA.summary.filter(r => r.total === 0).length;
  const slow = DATA.summary.filter(r => r.sales_status === "Slow seller").length;
  const activeNoSales = DATA.summary.filter(r => String(r.product_status).toUpperCase() === "ACTIVE" && r.total === 0).length;
  div.innerHTML = `
    <div class="insight">Best seller: <strong>${top.product}</strong> with <strong>${fmt(top.total)}</strong> units.</div>
    <div class="insight"><strong>${noSales}</strong> products have no sales in this period.</div>
    <div class="insight"><strong>${activeNoSales}</strong> active products have no sales.</div>
    <div class="insight">Selected product is <strong>${row.product_status}</strong> and its sales trend is <strong>${row.trend}</strong>.</div>
  `;
}
function renderPareto() {
  const rows = [...DATA.summary].sort((a,b)=>b.total-a.total).slice(0,15);
  Plotly.newPlot("paretoChart", [{
    x: rows.map(r=>r.total), y: rows.map(r=>r.product), type:"bar", orientation:"h",
    hovertemplate:"%{y}<br>Total sold: %{x}<extra></extra>"
  }], {
    title:"Top products by units sold",
    margin:{t:50,l:170,r:20,b:45},
    xaxis:{title:"Units sold"},
    yaxis:{autorange:"reversed"}
  }, {responsive:true, displaylogo:false});
}
function renderStatusSummary() {
  const counts = DATA.kpis.productStatusCounts;
  const div = document.getElementById("statusSummary");
  div.innerHTML = Object.keys(counts).sort().map(s => `
    <div class="status-count">
      <span>${s}</span>
      <strong>${counts[s]}</strong>
    </div>
  `).join("");

  const labels = Object.keys(counts).sort();
  Plotly.newPlot("statusChart", [{
    labels: labels, values: labels.map(l => counts[l]), type:"pie", hole:.45,
    hovertemplate:"%{label}<br>Products: %{value}<extra></extra>"
  }], {
    title:"Product count by status",
    margin:{t:45,l:20,r:20,b:20},
    showlegend:true
  }, {responsive:true, displaylogo:false});
}
function renderTable() {
  const pstatus = document.getElementById("productStatusFilter").value;
  const sstatus = document.getElementById("salesStatusFilter").value;
  const q = document.getElementById("searchBox").value.toLowerCase();
  let rows = DATA.summary.filter(r =>
    (pstatus === "All" || r.product_status === pstatus) &&
    (sstatus === "All" || r.sales_status === sstatus) &&
    r.product.toLowerCase().includes(q)
  );
  rows.sort((a,b) => {
    let av=a[sortKey], bv=b[sortKey];
    if (typeof av === "string") return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
    return sortAsc ? av-bv : bv-av;
  });
  const tbody = document.querySelector("#summaryTable tbody");
  tbody.innerHTML = rows.map(r => `
    <tr>
      <td>${r.product}</td>
      <td><span class="${productCls(r.product_status)}">${r.product_status}</span></td>
      <td>${fmt(r.total)}</td>
      <td><span class="${salesCls(r.sales_status)}">${r.sales_status}</span></td>
      <td>${r.weeks_with_sales}</td>
      <td>${r.avg_weekly}</td>
      <td>${fmt(r.peak_units)}</td>
      <td>${r.trend}</td>
    </tr>
  `).join("");
}
init();
</script>
