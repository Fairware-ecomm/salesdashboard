<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Sales by Product Dashboard</title>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
<style>
:root {
  --bg:#f7f7f4; --card:#ffffff; --ink:#22221f; --muted:#6b6b63; --line:#deded6;
  --green:#2c6e49; --amber:#b7791f; --red:#a33a3a; --blue:#2f5fca; --purple:#6b46c1;
}
* { box-sizing:border-box; }
body { margin:0; font-family: Inter, Arial, sans-serif; background:var(--bg); color:var(--ink); }
header { padding:24px 28px 12px; }
h1 { margin:0 0 6px; font-size:28px; }
.sub { color:var(--muted); font-size:14px; }
.wrap { padding:12px 28px 32px; }
.kpis { display:grid; grid-template-columns: repeat(6, minmax(140px,1fr)); gap:12px; margin-bottom:16px; }
.card { background:var(--card); border:1px solid var(--line); border-radius:14px; box-shadow:0 1px 3px rgba(0,0,0,.04); }
.kpi { padding:16px; }
.kpi .label { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
.kpi .value { font-size:26px; font-weight:750; margin-top:7px; }
.grid { display:grid; grid-template-columns: 320px 1fr; gap:16px; align-items:start; }
.panel { padding:16px; }
label { display:block; font-size:12px; color:var(--muted); margin-bottom:6px; }
select, input { width:100%; padding:10px 12px; border:1px solid var(--line); border-radius:10px; background:#fff; font-size:14px; }
.controls { display:grid; gap:12px; }
.badge { display:inline-block; padding:4px 8px; border-radius:999px; font-size:12px; font-weight:700; }
.best { background:#e6f3ed; color:var(--green); }
.moderate { background:#edf1ff; color:var(--blue); }
.slow { background:#fff2dc; color:var(--amber); }
.none { background:#fae8e8; color:var(--red); }
.active { background:#e6f3ed; color:var(--green); }
.draft { background:#edf1ff; color:var(--blue); }
.archived { background:#fae8e8; color:var(--red); }
.unlisted { background:#f1ebff; color:var(--purple); }
.unknown { background:#f0f0ed; color:#555; }
.metric-list { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:14px; }
.smallmetric { border:1px solid var(--line); border-radius:12px; padding:10px; }
.smallmetric span { display:block; color:var(--muted); font-size:12px; }
.smallmetric strong { display:block; font-size:18px; margin-top:4px; }
.chart { height:430px; }
.two { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:16px; }
table { width:100%; border-collapse:collapse; font-size:13px; }
th, td { padding:10px 8px; border-bottom:1px solid var(--line); text-align:left; }
th { cursor:pointer; color:var(--muted); font-size:12px; text-transform:uppercase; }
tr:hover { background:#fafaf8; }
.insights { margin-top:16px; display:grid; gap:8px; }
.insight { background:#fff; border-left:4px solid var(--green); padding:10px 12px; border-radius:8px; border-top:1px solid var(--line); border-right:1px solid var(--line); border-bottom:1px solid var(--line); }
.status-grid { display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:8px; margin-top:12px; }
.status-count { border:1px solid var(--line); border-radius:12px; padding:10px; }
.status-count span { display:block; color:var(--muted); font-size:12px; }
.status-count strong { font-size:20px; }
@media (max-width: 1100px) {
  .kpis { grid-template-columns: repeat(2, 1fr); }
  .grid, .two { grid-template-columns:1fr; }
}
</style>
</head>
<body>
<header>
  <h1>Sales by Product Dashboard</h1>
  <div class="sub">Interactive weekly sales view · <span id="dateRange"></span></div>
</header>
<div class="wrap">
  <section class="kpis">
    <div class="card kpi"><div class="label">Total units sold</div><div class="value" id="kpiTotal"></div></div>
    <div class="card kpi"><div class="label">Products with sales</div><div class="value" id="kpiActive"></div></div>
    <div class="card kpi"><div class="label">No-sales products</div><div class="value" id="kpiNoSales"></div></div>
    <div class="card kpi"><div class="label">Top 5 sales share</div><div class="value" id="kpiTop5"></div></div>
    <div class="card kpi"><div class="label">Best seller</div><div class="value" id="kpiBest" style="font-size:16px"></div></div>
    <div class="card kpi"><div class="label">Best seller units</div><div class="value" id="kpiBestUnits"></div></div>
  </section>

  <section class="grid">
    <aside class="card panel">
      <div class="controls">
        <div>
          <label for="productSelect">Product</label>
          <select id="productSelect"></select>
        </div>
        <div>
          <label for="productStatusFilter">Product status filter</label>
          <select id="productStatusFilter"><option value="All">All</option></select>
        </div>
        <div>
          <label for="salesStatusFilter">Sales status filter</label>
          <select id="salesStatusFilter">
            <option value="All">All</option>
            <option value="Best seller">Best sellers</option>
            <option value="Moderate">Moderate</option>
            <option value="Slow seller">Slow sellers</option>
            <option value="No sales">No sales</option>
          </select>
        </div>
        <div>
          <label for="searchBox">Search table</label>
          <input id="searchBox" placeholder="Type product name..." />
        </div>
      </div>
      <div style="margin-top:18px">
        <h3 id="detailName" style="margin-bottom:6px"></h3>
        <span id="detailProductStatus" class="badge"></span>
        <span id="detailSalesStatus" class="badge"></span>
        <div class="metric-list">
          <div class="smallmetric"><span>Total sold</span><strong id="dTotal"></strong></div>
          <div class="smallmetric"><span>Avg weekly</span><strong id="dAvg"></strong></div>
          <div class="smallmetric"><span>Weeks with sales</span><strong id="dWeeks"></strong></div>
          <div class="smallmetric"><span>Peak week</span><strong id="dPeak"></strong></div>
          <div class="smallmetric"><span>Peak units</span><strong id="dPeakUnits"></strong></div>
          <div class="smallmetric"><span>Trend</span><strong id="dTrend"></strong></div>
        </div>
      </div>
      <div class="insights" id="insights"></div>
    </aside>

    <main>
      <div class="card panel"><div id="lineChart" class="chart"></div></div>
      <div class="two">
        <div class="card panel"><div id="paretoChart" class="chart"></div></div>
        <div class="card panel">
          <h2 style="margin:0 0 8px">Product status summary</h2>
          <div id="statusSummary" class="status-grid"></div>
          <div id="statusChart" class="chart" style="height:300px"></div>
        </div>
      </div>
    </main>
  </section>

  <section class="card panel" style="margin-top:16px">
    <h2 style="margin-top:0">Product performance table</h2>
    <table id="summaryTable">
      <thead><tr>
        <th data-key="product">Product</th>
        <th data-key="product_status">Product status</th>
        <th data-key="total">Total sold</th>
        <th data-key="sales_status">Sales status</th>
        <th data-key="weeks_with_sales">Weeks with sales</th>
        <th data-key="avg_weekly">Avg weekly</th>
        <th data-key="peak_units">Peak units</th>
        <th data-key="trend">Trend</th>
      </tr></thead>
      <tbody></tbody>
    </table>
  </section>
</div>

